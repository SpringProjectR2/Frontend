{
  "expo": {
    "name": "springproject",
    "slug": "springproject",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "springproject",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.springproject"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "105ff41c-e63f-4ac7-955b-49339670c730"
      }
    },
    "owner": "jan5us-organization"
  }
}
